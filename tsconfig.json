{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2023",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["server.ts", "src/**/*", "lib/**/*", "prisma.config.ts"],
  "exclude": ["node_modules", "dist", "prisma/migrations"]
}
