{
  "name": "track-hire",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec tsx server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:prod:build": "docker compose build",
    "docker:prod:up": "docker compose up -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:logs": "docker compose logs -f",
    "clean": "rimraf dist node_modules",
    "clean:dist": "rimraf dist",
    "prebuild": "npm run clean:dist",
    "postinstall": "prisma generate"
  },
  "keywords": [],
