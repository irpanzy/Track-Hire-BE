    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "redis": "^6.0.0",
    "sharp": "^0.35.1",
    "swagger-jsdoc": "^6.3.0",
